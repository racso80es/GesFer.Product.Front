# API Product (desarrollo local). Siempre HTTPS. El navegador llama a esta URL.
# Perfil "https" en launchSettings: https://localhost:5001 (HTTP en 5000 redirige a 5001).
NEXT_PUBLIC_API_URL=https://localhost:5001

# Valores por defecto del formulario de login (deben coincidir con los seeds: demo-data.json).
# Facilita el login en desarrollo sin tener que recordar credenciales.
NEXT_PUBLIC_DEFAULT_LOGIN_COMPANY=Organización Cliente
NEXT_PUBLIC_DEFAULT_LOGIN_USER=user_test
NEXT_PUBLIC_DEFAULT_LOGIN_PASSWORD=admin123
