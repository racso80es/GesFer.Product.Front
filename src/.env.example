# Origen del API backend (sin barra final). Debe coincidir con el servicio que expone el OpenAPI (p. ej. /swagger/v1/swagger.json).
# Referencia local habitual: http://localhost:5020
# Si el backend usa HTTPS en otro puerto, ajusta (p. ej. https://localhost:7xxx).
NEXT_PUBLIC_API_URL=http://localhost:5020

# Auth.js (NextAuth): cifrado de la cookie de sesión de la app. Debe tener al menos 32 caracteres.
# No sustituye el Jwt:Key del backend en peticiones HTTP; el login sigue siendo POST /api/auth/login
# y el JWT lo firma solo la API. En desarrollo puedes usar la misma cadena larga que Jwt:Key en appsettings.
# En producción usa un valor aleatorio único (p. ej. openssl rand -base64 32) y pásalo también al contenedor.
AUTH_SECRET=YourSuperSecretKeyThatShouldBeAtLeast32CharactersLong

# Valores por defecto del formulario de login (deben coincidir con los seeds del backend / demo-data).
NEXT_PUBLIC_DEFAULT_LOGIN_COMPANY=Empresa Demo
NEXT_PUBLIC_DEFAULT_LOGIN_USER=admin
NEXT_PUBLIC_DEFAULT_LOGIN_PASSWORD=admin123

# Opcional — Jest `test:integrity` (login real contra la API). Si no las defines, se usan los mismos valores que arriba.
# Ajusta si tu seed de BD usa otros nombres de empresa o usuario.
# TEST_LOGIN_COMPANY=
# TEST_LOGIN_USER=
# TEST_LOGIN_PASSWORD=
